{
    "layer": "top",
    "position": "top",
    "margin": "10 20 0 20", // –І—Г—В—М –Љ–µ–љ—М—И–µ —Б–≤–µ—А—Е—Г, —З—В–Њ–±—Л –љ–µ –і–∞–≤–Є–ї–Њ
    
    "modules-left": ["keyboard-state", "hyprland/window"],
    "modules-center": ["clock"],
    "modules-right": ["custom/mem", "backlight", "battery", "pulseaudio", "tray"],
   
    "hyprland/window": {
       "format": "вЭДпЄП {}",
       "separate-outputs": true
     },

    "keyboard-state": {
        "capslock": true,
        "format": "{name} {icon}",
        "format-icons": {
            "locked": "пА£ ",
            "unlocked": "пВЬ"
        }
    },

    "clock": {
        "format": "{:%a, %d %b, %I:%M %p}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },

    "pulseaudio": {
        "reverse-scrolling": 1,
        "format": "{volume}% {icon}",
        "format-muted": "рЯФЗ Muted",
        "format-icons": {
            "default": ["пА¶", "пАІ", "пА®"]
        },
        "on-click": "pavucontrol"
    },

    "custom/mem": {
        "format": "{} п°Ъ",
        "interval": 3,
        "exec": "free -h | awk '/Mem:/{printf $3}'"
    },

    "backlight": {
        "device": "intel_backlight",
        "format": "{percent}% {icon}",
        "format-icons": ["пЧЩ","пЧЪ","пЧЫ","пЧЬ", "пЧЭ", "пЧЮ", "пЧЯ"]
    },

    "battery": {
        "states": { "warning": 30, "critical": 15 },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% пЦГ",
        "format-icons": ["пХє", "пХЇ", "пХї", "пХљ", "пХЄ"]
    },

    "tray": {
        "icon-size": 16,
        "spacing": 10
    }
}
